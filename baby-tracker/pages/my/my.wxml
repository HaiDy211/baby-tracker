<view class="container">
  <!-- 宝宝信息卡片 -->
  <view class="card baby-card">
    <!-- 头像区域 -->
    <view class="avatar-section">
      <view class="avatar-wrapper">
        <text class="avatar-icon">{{gender === 'boy' ? '👶🏻' : gender === 'girl' ? '👧🏻' : '👶'}}</text>
      </view>
      <view class="avatar-info">
        <text class="baby-name">{{babyName || '小宝宝'}}</text>
        <text class="baby-age" wx:if="{{babyAge}}">{{babyAge}}</text>
      </view>
    </view>
    
    <!-- 宝宝信息表单 -->
    <view class="info-form">
      <view class="form-row">
        <text class="form-label">宝宝姓名</text>
        <input 
          class="form-input"
          value="{{babyName}}"
          bindinput="inputName"
          placeholder="请输入宝宝姓名"
          maxlength="20"
        />
      </view>
      
      <view class="form-row">
        <text class="form-label">出生日期</text>
        <picker mode="date" value="{{birthDate}}" bindchange="bindDateChange">
          <view class="picker-value">
            <text>{{birthDate || '请选择'}}</text>
            <text class="arrow">›</text>
          </view>
        </picker>
      </view>
      
      <view class="form-row">
        <text class="form-label">性别</text>
        <view class="gender-select">
          <view 
            class="gender-item {{gender === 'boy' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="boy"
          >
            <text>👦</text>
            <text class="gender-text">男宝</text>
          </view>
          <view 
            class="gender-item {{gender === 'girl' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="girl"
          >
            <text>👧</text>
            <text class="gender-text">女宝</text>
          </view>
          <view 
            class="gender-item {{gender === 'unknown' ? 'active' : ''}}"
            bindtap="selectGender"
            data-gender="unknown"
          >
            <text>🤔</text>
            <text class="gender-text">未知</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 保存按钮 -->
    <button class="save-btn" bindtap="saveBabyInfo">
      <text>💾</text>
      <text>保存信息</text>
    </button>
  </view>

  <!-- 统计卡片 -->
  <view class="card stats-card">
    <text class="section-title">数据统计</text>
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-icon">📊</text>
        <text class="stats-number">{{stats.totalRecords}}</text>
        <text class="stats-label">总记录</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">🍼</text>
        <text class="stats-number">{{stats.totalFeed}}</text>
        <text class="stats-label">喂奶</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">🧷</text>
        <text class="stats-number">{{stats.totalDiaper}}</text>
        <text class="stats-label">尿布</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">😴</text>
        <text class="stats-number">{{stats.totalSleep}}</text>
        <text class="stats-label">睡眠</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">📈</text>
        <text class="stats-number">{{stats.totalGrowth}}</text>
        <text class="stats-label">成长</text>
      </view>
    </view>
  </view>

  <!-- 操作菜单 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="showAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
      </view>
      <text class="arrow">›</text>
    </view>
    
    <view class="menu-divider"></view>
    
    <view class="menu-item danger" bindtap="clearAllData">
      <view class="menu-left">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除所有数据</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>宝宝成长记录 v{{version}}</text>
  </view>

  <view class="bottom-space"></view>
</view>
