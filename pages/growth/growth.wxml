<view class="container">
  <wxs module="util" src="../../utils/util.wxs"></wxs>

  <!-- 记录表单 -->
  <view class="card form-card">
    <view class="form-header">
      <text class="form-title">{{isEditing ? '编辑记录' : '记录成长'}}</text>
    </view>

    <!-- 宝宝选择 -->
    <view class="form-row">
      <text class="form-label">宝宝</text>
      <picker mode="selector" range="{{babyList}}" range-key="name" bindchange="bindBabyChange">
        <view class="picker-value">
          <text>{{selectedBabyName || '请选择宝宝'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 记录日期 -->
    <view class="form-row">
      <text class="form-label">日期</text>
      <picker mode="date" value="{{recordDate}}" bindchange="bindDateChange">
        <view class="picker-value">
          <text>{{recordDate || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 身高 -->
    <view class="form-row">
      <text class="form-label">身高</text>
      <view class="input-group">
        <input 
          type="digit"
          class="form-input"
          value="{{formData.height}}"
          bindinput="inputHeight"
          placeholder="0"
        />
        <text class="input-suffix">cm</text>
      </view>
    </view>

    <!-- 体重 -->
    <view class="form-row">
      <text class="form-label">体重</text>
      <view class="input-group">
        <input 
          type="digit"
          class="form-input"
          value="{{formData.weight}}"
          bindinput="inputWeight"
          placeholder="0"
        />
        <text class="input-suffix">kg</text>
      </view>
    </view>

    <!-- 头围 -->
    <view class="form-row">
      <text class="form-label">头围</text>
      <view class="input-group">
        <input 
          type="digit"
          class="form-input"
          value="{{formData.headCircumference}}"
          bindinput="inputHeadCircumference"
          placeholder="选填"
        />
        <text class="input-suffix">cm</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-row">
      <text class="form-label">备注</text>
      <input 
        class="form-input"
        value="{{formData.notes}}"
        bindinput="inputNotes"
        placeholder="选填"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="form-actions" wx:if="{{isEditing}}">
      <button class="btn cancel-btn" bindtap="onCancel">取消</button>
      <button class="btn delete-btn" bindtap="onDelete">删除</button>
      <button class="btn save-btn" bindtap="saveRecord">保存</button>
    </view>
    <button class="btn primary-btn" bindtap="saveRecord" wx:else>💾 保存记录</button>
  </view>

  <!-- 记录列表 -->
  <view class="card records-card">
    <text class="section-title">成长记录</text>
    <view class="records-list" wx:if="{{records.length > 0}}">
      <view 
        class="record-item" 
        wx:for="{{records}}" 
        wx:key="_id"
        bindtap="onTapRecord"
        data-record="{{item}}"
      >
        <view class="record-date">
          <text class="date">{{item.data.date}}</text>
          <text class="record-user">{{item.userTitle}}</text>
        </view>
        <view class="record-content">
          <text class="record-detail" wx:if="{{item.data.height}}">身高: {{item.data.height}}cm</text>
          <text class="record-detail" wx:if="{{item.data.weight}}">体重: {{item.data.weight}}kg</text>
          <text class="record-detail" wx:if="{{item.data.headCircumference}}">头围: {{item.data.headCircumference}}cm</text>
          <text class="record-notes" wx:if="{{item.data.notes}}">{{item.data.notes}}</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无记录</text>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
