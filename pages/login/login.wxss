.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #87CEEB 0%, #E0F4FF 100%);
  padding: 100rpx 50rpx;
  box-sizing: border-box;
}

.step-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo 区域 */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 40rpx;
  background: #fff;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #666;
}

/* 登录按钮 */
.login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-btn {
  width: 600rpx;
  height: 96rpx;
  background: #07C160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.login-btn::after {
  border: none;
}

.login-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 步骤2: 设置昵称 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.step-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.step-desc {
  font-size: 28rpx;
  color: #666;
}

.nickname-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nickname-input {
  width: 600rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  padding: 0 40rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.05);
}

.confirm-btn {
  width: 600rpx;
  height: 96rpx;
  background: #07C160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-btn::after {
  border: none;
}

.title-suggestions {
  margin-top: 60rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.suggestions-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.suggestions-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
}

.suggestion-tag {
  padding: 15rpx 35rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}
