<view class="container">
  <view class="logo-section">
    <image class="logo" src="/images/baby-icon.png" mode="aspectFit"></image>
    <text class="app-name">宝宝成长记录</text>
    <text class="app-desc">记录宝宝每一天的成长</text>
  </view>

  <view class="login-section">
    <button 
      class="login-btn" 
      type="primary" 
      bindtap="onLogin"
      loading="{{isLoading}}"
    >
      微信授权登录
    </button>
    
    <text class="login-tip">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>
