<view class="container">
  <wxs module="util" src="../../utils/util.wxs"></wxs>

  <!-- 记录表单 -->
  <view class="card form-card">
    <view class="form-header">
      <text class="form-title">{{isEditing ? '编辑记录' : '记录喂奶'}}</text>
    </view>

    <!-- 宝宝选择 -->
    <view class="form-row">
      <text class="form-label">宝宝</text>
      <picker mode="selector" range="{{babyList}}" range-key="name" bindchange="bindBabyChange">
        <view class="picker-value">
          <text>{{selectedBabyName || '请选择宝宝'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 记录时间 -->
    <view class="form-row">
      <text class="form-label">时间</text>
      <picker mode="time" value="{{recordTime}}" bindchange="bindTimeChange">
        <view class="picker-value">
          <text>{{recordTime || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 喂奶方式 -->
    <view class="form-row">
      <text class="form-label">方式</text>
      <view class="method-select">
        <view 
          class="method-item {{formData.method === 'breast' ? 'active' : ''}}"
          bindtap="selectMethod" data-method="breast">
          <text>🤱</text>
          <text class="method-text">亲喂</text>
        </view>
        <view 
          class="method-item {{formData.method === 'bottle' ? 'active' : ''}}"
          bindtap="selectMethod" data-method="bottle">
          <text>🍼</text>
          <text class="method-text">瓶喂</text>
        </view>
      </view>
    </view>

    <!-- 亲喂时长 -->
    <view class="form-row" wx:if="{{formData.method === 'breast'}}">
      <text class="form-label">时长</text>
      <view class="input-group">
        <input 
          type="number"
          class="form-input"
          value="{{formData.duration}}"
          bindinput="inputDuration"
          placeholder="0"
        />
        <text class="input-suffix">分钟</text>
      </view>
    </view>

    <!-- 瓶喂奶量 -->
    <view class="form-row" wx:if="{{formData.method === 'bottle'}}">
      <text class="form-label">奶量</text>
      <view class="quick-select">
        <view 
          wx:for="{{[30, 60, 90, 120, 150, 180, 210, 240]}}" 
          wx:key="*this"
          class="quick-item {{formData.amount == item ? 'active' : ''}}"
          bindtap="quickSelectAmount"
          data-amount="{{item}}">
          {{item}}
        </view>
      </view>
      <view class="input-group">
        <input 
          type="number"
          class="form-input"
          value="{{formData.amount}}"
          bindinput="inputAmount"
          placeholder="其他"
        />
        <text class="input-suffix">ml</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-row">
      <text class="form-label">备注</text>
      <input 
        class="form-input"
        value="{{formData.notes}}"
        bindinput="inputNotes"
        placeholder="选填"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="form-actions" wx:if="{{isEditing}}">
      <button class="btn cancel-btn" bindtap="onCancel">取消</button>
      <button class="btn delete-btn" bindtap="onDelete">删除</button>
      <button class="btn save-btn" bindtap="saveRecord">保存</button>
    </view>
    <button class="btn primary-btn" bindtap="saveRecord" wx:else>💾 保存记录</button>
  </view>



  <view class="bottom-space"></view>
</view>
