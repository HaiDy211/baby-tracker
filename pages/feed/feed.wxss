/* 喂奶记录页面样式 */

.container {
  min-height: 100vh;
  background-color: #FFF5F8;
  padding-bottom: 30rpx;
}

.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.15);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 25rpx;
  display: block;
}

/* 喂奶方式选择 */
.method-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.method-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  background-color: #FFF8FA;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.method-item.active {
  background: linear-gradient(135deg, #FFE4E9 0%, #FFF0F3 100%);
  border-color: #FFB6C1;
}

.method-icon {
  font-size: 56rpx;
  margin-bottom: 15rpx;
}

.method-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.method-item.active .method-label {
  color: #FF6B8A;
}

/* 奶瓶容量 */
.bottle-input {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 25rpx;
}

.amount-control {
  display: flex;
  align-items: center;
  background-color: #FFF8FA;
  border-radius: 50rpx;
  padding: 10rpx;
}

.control-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
}

.amount-input {
  width: 150rpx;
  text-align: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #FF6B8A;
  margin: 0 20rpx;
  border: none;
}

.unit {
  font-size: 32rpx;
  color: #FF6B8A;
  margin-left: 15rpx;
  font-weight: 500;
}

.quick-amounts {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.quick-item {
  padding: 12rpx 28rpx;
  background-color: #FFE4E9;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #FF6B8A;
}

/* 时间选择 */
.time-input {
  display: flex;
  gap: 20rpx;
}

.picker-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 25rpx;
  background-color: #FFF8FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
}

.arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* 备注 */
.note-input {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  background-color: #FFF8FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-btn-wrapper {
  padding: 30rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 25rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  border: none;
  box-shadow: 0 8rpx 25rpx rgba(255, 182, 193, 0.4);
}

.submit-btn text:first-child {
  font-size: 36rpx;
  margin-right: 10rpx;
}

/* 最近记录 */
.recent-card {
  margin-top: 30rpx;
}

.recent-list {
  margin-top: 10rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background-color: #FFE4E9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.recent-content {
  flex: 1;
  margin-left: 20rpx;
}

.recent-detail {
  font-size: 28rpx;
  color: #333333;
  display: block;
  margin-bottom: 5rpx;
}

.recent-time {
  font-size: 22rpx;
  color: #999999;
}

.bottom-space {
  height: 50rpx;
}
