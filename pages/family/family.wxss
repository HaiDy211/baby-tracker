.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
}

.mode-tabs {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active {
  background-color: #FFB6C1;
  color: #fff;
  font-weight: bold;
}

.form-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.input {
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.code-input {
  letter-spacing: 8rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
}

.picker {
  height: 88rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.tips {
  background-color: #fff5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tips text {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 40rpx;
}

.btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary {
  background-color: #FFB6C1;
  color: #fff;
}

.btn-primary::after {
  border: none;
}
