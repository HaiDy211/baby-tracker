<view class="container">
  <!-- 顶部问候 -->
  <view class="header">
    <view class="greeting" bindtap="showBabyPicker">
      <text class="greeting-text">{{babyName}}</text>
      <text class="switch-btn" wx:if="{{babies.length > 1}}">切换</text>
    </view>
    <text class="date">{{util.getDate()}}</text>
  </view>

  <!-- 今日统计卡片 -->
  <view class="card stats-card">
    <text class="section-title">今日概览</text>
    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-icon" style="background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);">
          <text>🍼</text>
        </view>
        <view class="stat-info">
          <text class="stat-number">{{todayStats.feedCount}}</text>
          <text class="stat-label">喂奶次数</text>
        </view>
      </view>
      
      <view class="stat-item">
        <view class="stat-icon" style="background: linear-gradient(135deg, #B0E0E6 0%, #ADD8E6 100%);">
          <text>🧷</text>
        </view>
        <view class="stat-info">
          <text class="stat-number">{{todayStats.diaperCount}}</text>
          <text class="stat-label">换尿布次数</text>
        </view>
      </view>
      
      <view class="stat-item">
        <view class="stat-icon" style="background: linear-gradient(135deg, #DDA0DD 0%, #E6E6FA 100%);">
          <text>😴</text>
        </view>
        <view class="stat-info">
          <text class="stat-number">{{todayStats.sleepHours}}h</text>
          <text class="stat-label">睡眠时长</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作按钮 -->
  <view class="card quick-actions-card">
    <text class="section-title">快捷记录</text>
    <view class="quick-actions">
      <view class="quick-btn" bindtap="goToRecord" data-type="feed">
        <view class="quick-btn-icon" style="background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);">
          <text>🍼</text>
        </view>
        <text class="quick-btn-text">喂奶</text>
      </view>
      
      <view class="quick-btn" bindtap="goToRecord" data-type="diaper">
        <view class="quick-btn-icon" style="background: linear-gradient(135deg, #B0E0E6 0%, #ADD8E6 100%);">
          <text>🧷</text>
        </view>
        <text class="quick-btn-text">换尿布</text>
      </view>
      
      <view class="quick-btn" bindtap="goToRecord" data-type="sleep">
        <view class="quick-btn-icon" style="background: linear-gradient(135deg, #DDA0DD 0%, #E6E6FA 100%);">
          <text>😴</text>
        </view>
        <text class="quick-btn-text">睡觉</text>
      </view>
      
      <view class="quick-btn" bindtap="goToRecord" data-type="growth">
        <view class="quick-btn-icon" style="background: linear-gradient(135deg, #98FB98 0%, #90EE90 100%);">
          <text>📈</text>
        </view>
        <text class="quick-btn-text">成长</text>
      </view>
    </view>
  </view>

  <!-- 最近记录 -->
  <view class="card recent-card">
    <view class="card-header">
      <text class="section-title">最近记录</text>
      <view class="more-btn" bindtap="goToTimeline">
        <text>查看全部</text>
        <text class="arrow">›</text>
      </view>
    </view>
    
    <view wx:if="{{recentRecords.length > 0}}" class="recent-list">
      <view 
        wx:for="{{recentRecords}}" 
        wx:key="_id" 
        class="recent-item"
        bindtap="onTapRecord"
        data-id="{{item._id}}"
        data-type="{{item.type}}"
      >
        <view class="recent-icon" style="background-color: {{item.color}}20;">
          <text style="font-size: 36rpx;">{{item.icon}}</text>
        </view>
        <view class="recent-content">
          <view class="recent-top">
            <text class="recent-type">{{item.typeName}}</text>
            <text class="recent-time">{{item.relativeTime}}</text>
          </view>
          <text class="recent-detail">{{item.detail}}</text>
          <text class="recent-recorder">{{item.userTitle}}</text>
        </view>
      </view>
    </view>
    
    <view wx:else class="empty-state">
      <text class="empty-icon">👶</text>
      <text class="empty-text">还没有记录哦~</text>
      <text class="empty-hint">点击上方快捷按钮开始记录</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>
</view>

<!-- 宝宝选择弹窗 -->
<view class="picker-mask" wx:if="{{showBabyPicker}}" bindtap="hideBabyPicker">
  <view class="picker-content" catchtap="stopPropagation">
    <view class="picker-header">
      <text class="picker-title">选择宝宝</text>
    </view>
    <view class="picker-list">
      <view 
        wx:for="{{babies}}" 
        wx:key="babyId"
        class="picker-item {{currentBaby && currentBaby.babyId === item.babyId ? 'active' : ''}}"
        bindtap="onSelectBaby"
        data-id="{{item.babyId}}"
      >
        <image class="picker-avatar" src="{{item.avatar || '/images/baby-default.png'}}" mode="aspectFill"></image>
        <text class="picker-name">{{item.name}}</text>
        <text class="picker-check" wx:if="{{currentBaby && currentBaby.babyId === item.babyId}}">✓</text>
      </view>
    </view>
    <view class="picker-footer">
      <button class="picker-cancel" bindtap="hideBabyPicker">取消</button>
    </view>
  </view>
</view>

<!-- WXS工具模块 -->
<wxs module="util">
module.exports = {
  formatDate: function(date) {
    const months = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月']
    return months[date.getMonth()] + date.getDate() + '日'
  },
  getDate: function() {
    var now = getDate();
    return now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
  }
}
</wxs>
