/* 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F8 0%, #FFF8FA 100%);
  padding: 0;
}

/* 顶部问候 */
.header {
  padding: 40rpx 40rpx 20rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 50%, #FFD1DC 100%);
}

.greeting {
  margin-bottom: 10rpx;
}

.greeting-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.baby-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-left: 10rpx;
}

.date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 卡片容器 */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.15);
}

/* 今日统计 */
.stats-card {
  margin-top: -10rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.stat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 15rpx;
}

.stat-icon text {
  font-size: 36rpx;
}

.stat-info {
  text-align: center;
}

.stat-number {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF6B8A;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 5rpx;
  display: block;
}

/* 快捷操作 */
.quick-actions-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF8FA 100%);
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding: 10rpx 0;
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-btn-icon {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 15rpx;
  transition: transform 0.2s;
}

.quick-btn:active .quick-btn-icon {
  transform: scale(0.95);
}

.quick-btn-icon text {
  font-size: 48rpx;
}

.quick-btn-text {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

/* 最近记录 */
.recent-card {
  margin-bottom: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.more-btn {
  display: flex;
  align-items: center;
  color: #FFB6C1;
  font-size: 24rpx;
}

.arrow {
  font-size: 28rpx;
  margin-left: 5rpx;
}

.recent-list {
  margin-top: 10rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recent-content {
  flex: 1;
  margin-left: 20rpx;
}

.recent-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.recent-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.recent-time {
  font-size: 22rpx;
  color: #999999;
}

.recent-detail {
  font-size: 24rpx;
  color: #666666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  display: block;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 底部留白 */
.bottom-space {
  height: 30rpx;
}

/* 宝宝选择弹窗 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  width: 100%;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.picker-header {
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-list {
  max-height: 600rpx;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background-color: #f9f9f9;
}

.picker-item.active {
  background-color: #fff5f5;
  border: 2rpx solid #FFB6C1;
}

.picker-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.picker-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.picker-check {
  font-size: 36rpx;
  color: #FFB6C1;
}

.picker-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
}

.picker-cancel {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.picker-cancel::after {
  border: none;
}

/* 切换按钮 */
.switch-btn {
  font-size: 24rpx;
  color: #FFB6C1;
  background-color: #fff5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
}

/* 记录人 */
.recent-recorder {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
