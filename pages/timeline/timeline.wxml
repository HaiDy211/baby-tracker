<view class="container">
  <!-- 筛选区域 -->
  <view class="filter-section">
    <!-- 类型筛选 -->
    <scroll-view scroll-x class="filter-tabs">
      <view 
        class="filter-tab {{filterType === 'all' ? 'active' : ''}}"
        bindtap="selectFilterType"
        data-type="all"
      >
        <text>全部</text>
      </view>
      <view 
        class="filter-tab {{filterType === 'feed' ? 'active' : ''}}"
        bindtap="selectFilterType"
        data-type="feed"
      >
        <text>🍼</text>
        <text class="tab-text">喂奶</text>
      </view>
      <view 
        class="filter-tab {{filterType === 'diaper' ? 'active' : ''}}"
        bindtap="selectFilterType"
        data-type="diaper"
      >
        <text>🧷</text>
        <text class="tab-text">尿布</text>
      </view>
      <view 
        class="filter-tab {{filterType === 'sleep' ? 'active' : ''}}"
        bindtap="selectFilterType"
        data-type="sleep"
      >
        <text>😴</text>
        <text class="tab-text">睡眠</text>
      </view>
      <view 
        class="filter-tab {{filterType === 'growth' ? 'active' : ''}}"
        bindtap="selectFilterType"
        data-type="growth"
      >
        <text>📈</text>
        <text class="tab-text">成长</text>
      </view>
    </scroll-view>
    
    <!-- 日期筛选 -->
    <view class="date-filter">
      <picker mode="date" value="{{filterDate}}" bindchange="bindDateFilter">
        <view class="date-picker">
          <text class="date-icon">📅</text>
          <text class="date-text">{{filterDate || '选择日期'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
      <view class="clear-btn" bindtap="clearDateFilter" wx:if="{{filterDate}}">
        <text>清除</text>
      </view>
    </view>
  </view>

  <!-- 记录统计 -->
  <view class="stats-bar">
    <text class="stats-text">共 {{totalCount}} 条记录</text>
  </view>

  <!-- 时间线内容 -->
  <view class="timeline-content" wx:if="{{dateList.length > 0}}">
    <view wx:for="{{dateList}}" wx:key="date" class="date-group">
      <!-- 日期头部 -->
      <view class="date-header">
        <view class="date-info">
          <text class="date-day">{{util.getFriendlyDate(item)}}</text>
        </view>
        <text class="record-count">{{groupedRecords[item].length}}条</text>
      </view>
      
      <!-- 记录列表 -->
      <view class="record-list">
        <view 
          wx:for="{{groupedRecords[item]}}" 
          wx:for-item="record"
          wx:key="id"
          class="record-item"
          bindlongpress="onLongPressRecord"
          data-id="{{record.id}}"
        >
          <!-- 时间线节点 -->
          <view class="timeline-node">
            <view class="node-dot" style="background-color: {{record.color}}"></view>
            <view class="node-line"></view>
          </view>
          
          <!-- 记录内容 -->
          <view class="record-content">
            <view class="record-header">
              <view class="record-icon" style="background-color: {{record.color}}20;">
                <text style="font-size: 32rpx;">{{record.icon}}</text>
              </view>
              <view class="record-info">
                <text class="record-type">{{record.typeName}}</text>
                <text class="record-time">{{record.time}}</text>
              </view>
            </view>
            <view class="record-detail">
              <text>{{getRecordDetail(record)}}</text>
            </view>
            <view class="record-note" wx:if="{{record.note}}">
              <text>{{record.note}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📝</text>
    <text class="empty-title">暂无记录</text>
    <text class="empty-desc">快去记录宝宝的日常吧~</text>
    <view class="quick-add">
      <view class="quick-btn" bindtap="goToRecord" data-type="feed">
        <text>🍼 喂奶</text>
      </view>
      <view class="quick-btn" bindtap="goToRecord" data-type="diaper">
        <text>🧷 尿布</text>
      </view>
      <view class="quick-btn" bindtap="goToRecord" data-type="sleep">
        <text>😴 睡眠</text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>
</view>

<!-- WXS工具模块 -->
<wxs module="util">
module.exports = {
  getFriendlyDate: function(dateStr) {
    var date = new Date(dateStr);
    var now = new Date();
    var today = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0') + '-' + String(now.getDate()).padStart(2, '0');
    var yesterday = new Date(now);
    yesterday.setDate(yesterday.getDate() - 1);
    var yesterdayStr = yesterday.getFullYear() + '-' + String(yesterday.getMonth() + 1).padStart(2, '0') + '-' + String(yesterday.getDate()).padStart(2, '0');
    
    if (dateStr === today) return '今天';
    if (dateStr === yesterdayStr) return '昨天';
    
    var weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
    return dateStr + ' ' + weekdays[date.getDay()];
  }
}
</wxs>
