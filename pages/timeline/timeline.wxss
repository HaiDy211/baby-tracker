/* 时间线页面样式 */

.container {
  min-height: 100vh;
  background-color: #FFF5F8;
}

/* 筛选区域 */
.filter-section {
  background-color: #FFFFFF;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-tabs {
  white-space: nowrap;
  padding: 0 20rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 15rpx;
  border-radius: 30rpx;
  background-color: #FFF8FA;
  font-size: 26rpx;
  color: #666666;
}

.filter-tab.active {
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  color: #FFFFFF;
}

.tab-text {
  margin-left: 8rpx;
}

/* 日期筛选 */
.date-filter {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx 0;
}

.date-picker {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #FFF8FA;
  border-radius: 12rpx;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.date-text {
  font-size: 26rpx;
  color: #333333;
}

.arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 10rpx;
}

.clear-btn {
  padding: 12rpx 24rpx;
  background-color: #FFE4E9;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #FF6B8A;
}

/* 统计栏 */
.stats-bar {
  padding: 20rpx 30rpx;
  background-color: #FFF8FA;
}

.stats-text {
  font-size: 24rpx;
  color: #999999;
}

/* 日期分组 */
.date-group {
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-left: 12rpx;
}

.date-day {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.record-count {
  font-size: 24rpx;
  color: #999999;
  background-color: #F5F5F5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 记录列表 */
.record-list {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  padding: 25rpx 25rpx 25rpx 20rpx;
  position: relative;
}

.record-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 55rpx;
  bottom: 0;
  right: 25rpx;
  height: 1rpx;
  background-color: #F5F5F5;
}

/* 时间线节点 */
.timeline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 25rpx;
  width: 30rpx;
}

.node-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(255, 182, 193, 0.3);
}

.node-line {
  width: 2rpx;
  flex: 1;
  background-color: #F0F0F0;
  margin-top: 8rpx;
}

.record-item:last-child .node-line {
  display: none;
}

/* 记录内容 */
.record-content {
  flex: 1;
}

.record-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 15rpx;
}

.record-info {
  flex: 1;
}

.record-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
}

.record-time {
  font-size: 22rpx;
  color: #999999;
  margin-top: 2rpx;
}

.record-detail {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.record-note {
  font-size: 22rpx;
  color: #999999;
  padding: 10rpx 15rpx;
  background-color: #F8F8F8;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 50rpx;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 15rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 50rpx;
}

.quick-add {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.quick-btn {
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #FFB6C1 0%, #FFC0CB 100%);
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.bottom-space {
  height: 30rpx;
}
