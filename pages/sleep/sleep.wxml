<view class="container">
  <wxs module="util" src="../../utils/util.wxs"></wxs>

  <!-- 记录表单 -->
  <view class="card form-card">
    <view class="form-header">
      <text class="form-title">{{isEditing ? '编辑记录' : '记录睡眠'}}</text>
    </view>

    <!-- 宝宝选择 -->
    <view class="form-row">
      <text class="form-label">宝宝</text>
      <picker mode="selector" range="{{babyList}}" range-key="name" bindchange="bindBabyChange">
        <view class="picker-value">
          <text>{{selectedBabyName || '请选择宝宝'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 入睡时间 -->
    <view class="form-row">
      <text class="form-label">入睡</text>
      <picker mode="time" value="{{sleepTime}}" bindchange="bindSleepTimeChange">
        <view class="picker-value">
          <text>{{sleepTime || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 醒来时间 -->
    <view class="form-row">
      <text class="form-label">醒来</text>
      <picker mode="time" value="{{wakeTime}}" bindchange="bindWakeTimeChange">
        <view class="picker-value">
          <text>{{wakeTime || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 睡眠时长 -->
    <view class="form-row" wx:if="{{duration > 0}}">
      <text class="form-label">时长</text>
      <view class="duration-display">
        <text class="duration-value">{{duration}}</text>
        <text class="duration-unit">分钟</text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-row">
      <text class="form-label">备注</text>
      <input 
        class="form-input"
        value="{{formData.notes}}"
        bindinput="inputNotes"
        placeholder="选填"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="form-actions" wx:if="{{isEditing}}">
      <button class="btn cancel-btn" bindtap="onCancel">取消</button>
      <button class="btn delete-btn" bindtap="onDelete">删除</button>
      <button class="btn save-btn" bindtap="saveRecord">保存</button>
    </view>
    <button class="btn primary-btn" bindtap="saveRecord" wx:else>💾 保存记录</button>
  </view>



  <view class="bottom-space"></view>
</view>
