<view class="container">
  <wxs module="util" src="../../utils/util.wxs"></wxs>

  <!-- 记录表单 -->
  <view class="card form-card">
    <view class="form-header">
      <text class="form-title">{{isEditing ? '编辑记录' : '记录尿布'}}</text>
    </view>

    <!-- 宝宝选择 -->
    <view class="form-row">
      <text class="form-label">宝宝</text>
      <picker mode="selector" range="{{babyList}}" range-key="name" bindchange="bindBabyChange">
        <view class="picker-value">
          <text>{{selectedBabyName || '请选择宝宝'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 记录时间 -->
    <view class="form-row">
      <text class="form-label">时间</text>
      <picker mode="time" value="{{recordTime}}" bindchange="bindTimeChange">
        <view class="picker-value">
          <text>{{recordTime || '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 尿布类型 -->
    <view class="form-row">
      <text class="form-label">类型</text>
      <view class="type-select">
        <view 
          class="status-item {{formData.type === 'pee' ? 'active' : ''}}"
          bindtap="selectType" data-type="pee">
          <text>💧</text>
          <text class="type-text">小便</text>
        </view>
        <view 
          class="status-item {{formData.type === 'poop' ? 'active' : ''}}"
          bindtap="selectType" data-type="poop">
          <text>💩</text>
          <text class="type-text">大便</text>
        </view>
        <view 
          class="status-item {{formData.type === 'both' ? 'active' : ''}}"
          bindtap="selectType" data-type="both">
          <text>💪</text>
          <text class="type-text">都有</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-row">
      <text class="form-label">备注</text>
      <input 
        class="form-input"
        value="{{formData.notes}}"
        bindinput="inputNotes"
        placeholder="选填"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="form-actions" wx:if="{{isEditing}}">
      <button class="btn cancel-btn" bindtap="onCancel">取消</button>
      <button class="btn delete-btn" bindtap="onDelete">删除</button>
      <button class="btn save-btn" bindtap="saveRecord">保存</button>
    </view>
    <button class="btn primary-btn" bindtap="saveRecord" wx:else>💾 保存记录</button>
  </view>



  <view class="bottom-space"></view>
</view>
