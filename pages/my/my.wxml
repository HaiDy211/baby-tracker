<view class="container">
  <!-- 用户信息卡片 -->
  <view class="card user-card">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickname || '用户'}}</text>
        <text class="family-name" wx:if="{{familyInfo}}">{{familyInfo.name}}</text>
      </view>
    </view>
  </view>

  <!-- 宝宝信息卡片 -->
  <view class="card baby-card" bindtap="goToBabies">
    <view class="baby-info">
      <view class="baby-avatar">
        <text>{{currentBaby.gender === 'boy' ? '👶🏻' : currentBaby.gender === 'girl' ? '👧🏻' : '👶'}}</text>
      </view>
      <view class="baby-detail">
        <text class="baby-name">{{currentBaby.name || '请添加宝宝'}}</text>
        <text class="baby-age" wx:if="{{currentBaby.birthDate}}">生日: {{currentBaby.birthDate}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
    <view class="baby-tip">点击管理宝宝</view>
  </view>

  <!-- 家庭管理卡片 -->
  <view class="card family-card" wx:if="{{familyInfo}}">
    <view class="card-header">
      <text class="section-title">家庭管理</text>
    </view>
    
    <view class="family-info">
      <view class="invite-code-section">
        <text class="invite-label">邀请码</text>
        <text class="invite-code">{{familyInfo.inviteCode}}</text>
      </view>
      <text class="invite-hint">分享给家人加入</text>
    </view>

    <view class="menu-item" bindtap="goToFamilySettings">
      <view class="menu-left">
        <text class="menu-icon">👨‍👩‍👧</text>
        <text class="menu-text">家庭设置</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="card stats-card">
    <text class="section-title">数据统计</text>
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-icon">📊</text>
        <text class="stats-number">{{stats.totalRecords}}</text>
        <text class="stats-label">总记录</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">🍼</text>
        <text class="stats-number">{{stats.totalFeed}}</text>
        <text class="stats-label">喂奶</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">🧷</text>
        <text class="stats-number">{{stats.totalDiaper}}</text>
        <text class="stats-label">尿布</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">😴</text>
        <text class="stats-number">{{stats.totalSleep}}</text>
        <text class="stats-label">睡眠</text>
      </view>
      <view class="stats-item">
        <text class="stats-icon">📈</text>
        <text class="stats-number">{{stats.totalGrowth}}</text>
        <text class="stats-label">成长</text>
      </view>
    </view>
  </view>

  <!-- 操作菜单 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="showAbout">
      <view class="menu-left">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
      </view>
      <text class="arrow">›</text>
    </view>
    
    <view class="menu-divider"></view>
    
    <view class="menu-item danger" bindtap="onLogout">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-text">退出登录</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>宝宝成长记录 v{{version}}</text>
  </view>

  <view class="bottom-space"></view>
</view>
