/* 我的页面样式 */

.container {
  min-height: 100vh;
  background-color: #FFF5F8;
  padding-bottom: 30rpx;
}

.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.15);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 25rpx;
  display: block;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #FFE4E9 0%, #FFF0F3 100%);
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.user-detail {
  margin-left: 25rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.family-name {
  font-size: 26rpx;
  color: #FF6B8A;
  background-color: rgba(255, 107, 138, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 宝宝信息卡片 */
.baby-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF8FA 100%);
  padding: 25rpx 30rpx;
}

.baby-info {
  display: flex;
  align-items: center;
}

.baby-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE4E9 0%, #FFF0F3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
}

.baby-detail {
  margin-left: 25rpx;
  flex: 1;
}

.baby-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.baby-age {
  font-size: 26rpx;
  color: #999999;
}

.baby-tip {
  font-size: 24rpx;
  color: #FFB6C1;
  text-align: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #FFE4E9;
}

/* 家庭管理卡片 */
.family-card {
  background: linear-gradient(135deg, #FFF8E6 0%, #FFFDF5 100%);
}

.card-header {
  margin-bottom: 20rpx;
}

.family-info {
  background-color: #FFF;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.invite-code-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.invite-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 15rpx;
}

.invite-code {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF6B8A;
  letter-spacing: 8rpx;
}

.invite-hint {
  font-size: 24rpx;
  color: #999999;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFAF5 100%);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background-color: #FFF8FA;
  border-radius: 12rpx;
}

.stats-icon {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.stats-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B8A;
}

.stats-label {
  font-size: 20rpx;
  color: #999999;
  margin-top: 5rpx;
}

/* 菜单卡片 */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}

.menu-item.danger .menu-icon,
.menu-item.danger .menu-text {
  color: #FF6B6B;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333333;
}

.menu-divider {
  height: 1rpx;
  background-color: #F5F5F5;
  margin: 0 30rpx;
}

.arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  margin-left: 10rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 24rpx;
  color: #CCCCCC;
  margin-top: 30rpx;
  padding-bottom: 30rpx;
}

.bottom-space {
  height: 150rpx;
}
